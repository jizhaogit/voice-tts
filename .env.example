PORT=7860
HOST=0.0.0.0

# ── TTS Engine ────────────────────────────────────────────────────────────────
# cosyvoice2  : CosyVoice 2 (Alibaba) — best Chinese quality, ~4.8 GB, 4 GB VRAM
# indextts    : IndexTTS 1.5 (Bilibili) — strong Chinese/EN, ~5.9 GB, 8 GB VRAM
TTS_ENGINE=cosyvoice2

# Chunk size (chars) per TTS segment — smaller = more natural pauses
TTS_CHUNK_SIZE=250
